# ----------------------------------------------------
# Part 2: How long is the rereading? (LMM)
# Subset to RR > 0 only, then log-transform
# Interpretation: Conditional on rereading occurring,
#                 does emotional valence affect duration?
# ----------------------------------------------------

df_rr_nonzero <- df_final %>% filter(IA_REREADING_TIME > 0)

# Step 1: Maximum random structure
model_rr_part2_full <- lmer(
  log(IA_REREADING_TIME) ~ Condition +
    (1 + Condition | ID) + (1 | Item),
  data = df_rr_nonzero
)
summary(model_rr_part2_full)

