# =====================================================
# Model4_RR: Two-part Model
# Aline's suggestion: logistic GLMM + LMM on log-transformed data
# =====================================================

# Create binary outcome variable
# ReRead = 1 if RR > 0, ReRead = 0 if RR = 0
df_final$ReRead <- ifelse(df_final$IA_REREADING_TIME > 0, 1, 0)



# ----------------------------------------------------
# Part 1: Does rereading occur? (Logistic GLMM)
# Interpretation: Do emotional texts increase probability of rereading?
# ----------------------------------------------------

# Step 1: Maximum random structure
model_rr_part1_full <- glmer(
  ReRead ~ Condition +
    (1 + Condition | ID) + (1 | Item),
  data = df_final,
  family = binomial,
  control = glmerControl(optimizer = "bobyqa")
)
summary(model_rr_part1_full)

