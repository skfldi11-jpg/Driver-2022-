# =====================================================
# Model4_RFD: Two-part Model
# Aline's suggestion: logistic GLMM + LMM on log-transformed data
# =====================================================

# Create binary outcome variable
# ReFixate = 1 if RFD > 0, ReFixate = 0 if RFD = 0
df_final$ReFixate <- ifelse(df_final$IA_REFIXATION_DURATION > 0, 1, 0)



# ----------------------------------------------------
# Part 1: Does refixation occur? (Logistic GLMM)
# Interpretation: Do emotional texts increase probability of refixation?
# ----------------------------------------------------



# Step 1: Maximum random structure
model_rfd_part1_full <- glmer(
  ReFixate ~ Condition +
    (1 + Condition | ID) + (1 | Item),
  data = df_final,
  family = binomial,
  control = glmerControl(optimizer = "bobyqa")
)
summary(model_rfd_part1_full)
# Check: singular fit? → if yes, proceed to Step 2

