# ----------------------------------------------------
# Part 2: How long is the refixation? (LMM)
# Subset to RFD > 0 only, then log-transform
# Interpretation: Conditional on refixation occurring,
#                 does emotional valence affect duration?
# ----------------------------------------------------

df_rfd_nonzero <- df_final %>% filter(IA_REFIXATION_DURATION > 0)

# Step 1: Maximum random structure
model_rfd_part2_full <- lmer(
  log(IA_REFIXATION_DURATION) ~ Condition +
    (1 + Condition | ID) + (1 | Item),
  data = df_rfd_nonzero
)
summary(model_rfd_part2_full)

